---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';

const timeline = [
  {
    year: '2021–2026',
    role: 'Software Engineer 2',
    company: 'Microsoft Corporation',
    desc: 'Owned two high-impact internal products serving 5,000+ daily users across the Azure org — a change management tool and a code coverage analytics platform.',
  },
  {
    year: '2017–2021',
    role: 'Associate Senior Software Engineer',
    company: 'Oracle Health (Cerner)',
    desc: 'Designed and implemented backend REST APIs for patient and encounter registration workflows within large-scale healthcare systems.',
  },
  {
    year: '2017',
    role: 'M.S. Computer Engineering',
    company: 'Arizona State University',
    desc: 'Specialized in Computer Systems. Tempe, AZ.',
  },
  {
    year: '2014',
    role: 'B.E. Electronics Engineering',
    company: 'University of Mumbai',
    desc: 'Mumbai, India.',
  },
];

const interests = [
  'Financial Tools',
  'Hiking',
  'PC Gaming',
  'Strategy Games',
  'Chess',
  'Photography',
  'Road Trips'
];
---

<Layout title="About — Abhishek Joshi" description="Who I am, what I do, and how I got here.">
  <section class="section pt-20 md:pt-28">
    <div class="container-wide">
      <div class="grid grid-cols-1 md:grid-cols-[1fr,2fr] gap-12 md:gap-10">

        <!-- Sidebar -->
        <aside class="reveal">
          <!-- Avatar placeholder -->
          <div class="w-24 h-24 rounded-2xl mb-6 overflow-hidden"
               style="background: linear-gradient(135deg, var(--accent) 0%, var(--bg-elevated) 100%);">
            <div class="w-full h-full flex items-center justify-center text-3xl font-bold"
                 style="font-family: 'Bricolage Grotesque', sans-serif; color: var(--bg);">AJ</div>
          </div>

          <h1 class="text-2xl font-bold mb-1" style="margin-top:1rem;">Abhishek Joshi</h1>
          <p class="text-sm mb-4" style="color: var(--text-muted); margin-bottom:1rem;">
            Software Engineer · Vancouver, BC
          </p>

          <div class="flex flex-col gap-1 mb-8">
            <a href="mailto:hello@yourname.dev"
               class="text-sm flex items-center gap-2 transition-colors"
               style="color: var(--accent);">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
              hello@yourname.dev
            </a>
            <a href="https://github.com/Abhishek-P-Joshi" target="_blank" rel="noopener"
               class="text-sm flex items-center gap-2 transition-colors"
               style="color: var(--text-muted);"
               onmouseover="this.style.color='var(--text)'"
               onmouseout="this.style.color='var(--text-muted)'">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
              </svg>
              Abhishek-P-Joshi
            </a>
            <a href="https://linkedin.com/in/abhishek-joshi-5619a676" target="_blank" rel="noopener"
               class="text-sm flex items-center gap-2 transition-colors"
               style="color: var(--text-muted);"
               onmouseover="this.style.color='var(--text)'"
               onmouseout="this.style.color='var(--text-muted)'">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
                <rect x="2" y="9" width="4" height="12"/>
                <circle cx="4" cy="4" r="2"/>
              </svg>
              LinkedIn
            </a>
          </div>

          <div class="mb-6" style="margin-top:1rem; margin-bottom:1rem;">
            <p class="text-xs font-semibold uppercase tracking-widest mb-4" style="color: var(--text-faint);">
              Outside work
            </p>
            <div class="flex flex-wrap gap-2" style="margin-top:1rem;">
              {interests.map((interest) => (
                <span class="tag text-xs">{interest}</span>
              ))}
            </div>
          </div>

          <Button href="/abhishek-joshi-resume.pdf" variant="secondary" external>
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
              <line x1="16" y1="13" x2="8" y2="13"/>
              <line x1="16" y1="17" x2="8" y2="17"/>
            </svg>
            Download resume
          </Button>
        </aside>

        <!-- Main content -->
        <main class="reveal">
          <p class="section-label">About</p>
          <h2 class="text-3xl md:text-4xl font-bold mb-6" style="margin-bottom:0.5em">
            Full ownership, from architecture to production.
          </h2>

          <div class="prose-custom">
            <p>
              I'm a software engineer with 8.5+ years of experience who thrives at the intersection of
              software, infrastructure, and data. I care about building reliable systems, driving adoption 
              across teams, and taking full ownership from architecture to production.
            </p>
            <p>
              Most recently at Microsoft, I've led the development of two high-impact internal products: SafeFly, 
              a change management platform serving 5,000+ daily users, and a code coverage analytics system 
              adopted by 100+ engineering teams across the Azure org. My work spans backend development, cloud 
              infrastructure on Azure, DevOps, data pipelines, and security compliance.
            </p>
            <p>
              Before Microsoft, I spent four years at Oracle Health (formerly Cerner) building backend APIs for 
              large-scale healthcare systems, where I also led security initiatives, upgraded testing frameworks, 
              and mentored new engineers joining the team.
            </p>
            <p>
              Outside of work, I enjoy building things independently — most recently
              <a href="https://moneymath.ajtech.dev">MoneyMath</a>, a personal finance tools platform, and
              <a href="https://wordsolitaire.ajtech.dev">Word Solitaire</a>, a browser-based word game, 
              both built with React, TypeScript, and modern cloud tooling.
            </p>
            <p>
              I recently relocated to Vancouver, BC from the Seattle area, where I spent several years at Microsoft's 
              Redmond campus. I'm currently open to senior software engineering roles in Canada or remote positions across North America.
            </p>
          </div>

          <!-- Timeline -->
          <div class="mt-12">
            <p class="text-xs font-semibold uppercase tracking-widest mb-6" style="color: var(--text-faint); margin-top:1rem; margin-bottom:1rem;">
              Experience & Education
            </p>
            <div class="relative">
              <!-- Vertical line -->
              <div class="absolute left-3.5 top-2 bottom-2 w-px" style="background-color: var(--border);"></div>

              <div class="flex flex-col gap-8">
                {timeline.map((item) => (
                  <div class="flex gap-6 pl-0">
                    <!-- Dot -->
                    <div class="relative shrink-0 mt-1">
                      <div class="w-7 h-7 rounded-full border-2 flex items-center justify-center"
                           style="background-color: var(--bg); border-color: var(--border-mid);">
                        <div class="w-2 h-2 rounded-full" style="background-color: var(--accent);"></div>
                      </div>
                    </div>
                    <!-- Content -->
                    <div class="pb-2">
                      <div class="flex flex-wrap items-baseline gap-2 mb-1">
                        <h3 class="text-base font-bold">{item.role}</h3>
                        <span class="text-sm font-medium" style="color: var(--accent);">{item.company}</span>
                      </div>
                      <p class="text-xs mb-2 font-medium tabular-nums" style="color: var(--text-faint);">
                        {item.year}
                      </p>
                      <p class="text-sm leading-relaxed" style="color: var(--text-muted);">
                        {item.desc}
                      </p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </main>
      </div>
    </div>
  </section>
</Layout>
