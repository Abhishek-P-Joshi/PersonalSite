---
import Layout from '../../layouts/Layout.astro';

const post = {
  title: 'Building PKB MCP: Turning My Digital Chaos into a Queryable Brain',
  date: 'April 17, 2026',
  readTime: '14 min',
  tags: ['Python', 'MCP', 'SQLite', 'AI', 'Architecture'],
  excerpt: 'I had 1,400+ saved YouTube videos, an Obsidian vault full of notes, and no good way to find any of it. So I built a locally-hosted MCP server that connects it all to Claude Desktop — and the design decisions along the way were more interesting than I expected.',
};
---

<Layout title={`${post.title} — Abhishek Joshi`} description={post.excerpt}>
  <article class="section pt-16 md:pt-24">

