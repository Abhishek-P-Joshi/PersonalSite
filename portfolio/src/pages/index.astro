---
import Layout from '../layouts/Layout.astro';
import Tag from '../components/Tag.astro';
import Button from '../components/Button.astro';

const projects = [
  {
    title: 'MoneyMath',
    description: 'A personal finance tools platform featuring a retirement calculator, with more tools under active development. Full-stack, end-to-end.',
    tags: ['React', 'TypeScript', 'Supabase', 'Vercel'],
    href: 'https://moneymath.ajtech.dev',
    external: true,
    year: '2024',
    accent: '#059669',
    accentBg: 'rgba(5,150,105,0.08)',
  },
  {
    title: 'Word Solitaire',
    description: 'A browser-based word association solitaire game built entirely in React and TypeScript — no backend, all game state and logic on the frontend.',
    tags: ['React', 'TypeScript', 'Vercel'],
    href: 'https://wordsolitaire.ajtech.dev',
    external: true,
    year: '2024',
    accent: '#7C3AED',
    accentBg: 'rgba(124,58,237,0.08)',
  },
];

const posts = [
  {
    title: 'Building MoneyMath: A Journey into Phased Retirement Planning',
    date: 'Apr 5, 2026',
    slug: 'building-moneymath',
    readTime: '8 min',
    tags: ['React', 'Product'],
  },
];

const stack = [
  { name: 'TypeScript', icon: '⬡' },
  { name: 'React', icon: '⬡' },
  { name: 'Python', icon: '⬡' },
  { name: 'C#', icon: '⬡' },
  { name: 'Azure', icon: '⬡' },
  { name: 'SQL', icon: '⬡' },
  { name: 'Angular', icon: '⬡' },
  { name: 'Supabase', icon: '⬡' },
  { name: 'Power BI', icon: '⬡' },
  { name: 'Bicep', icon: '⬡' },
];
---

<Layout title="Abhishek Joshi — Software Engineer">
  <!-- ── Hero ──────────────────────────────────────────── -->
  <section class="section pt-24 md:pt-32 pb-20 md:pb-28 relative overflow-hidden">
    <!-- Background decoration -->
    <div class="absolute -top-1/2 left-1/2 -translate-x-1/2 w-[800px] h-[800px] rounded-full opacity-[0.025] blur-3xl pointer-events-none"
         style="background: radial-gradient(circle, var(--accent) 0%, transparent 70%);"></div>

    <div class="container-wide relative">
      <!-- Status badge -->
      <div class="mb-8 animate-fade-in">
        <span class="tag-accent inline-flex items-center gap-1.5 px-3 py-1">
          <span class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"></span>
          Open to new opportunities
        </span>
      </div>

      <!-- Headline -->
      <h1 class="text-5xl sm:text-6xl md:text-7xl font-bold leading-[1.05] tracking-tight animate-fade-up"
          style="margin-bottom: 2.5rem; animation-delay:0.05s; animation-fill-mode:both;">
        Building reliable<br />
        <span class="relative inline-block">
          systems.
          <!-- Amber underline accent -->
          <svg class="absolute -bottom-1 left-0 w-full h-1.5 opacity-60"
               viewBox="0 0 300 6" preserveAspectRatio="none">
            <path d="M0 3 Q75 0 150 3 Q225 6 300 3" stroke="var(--accent)" stroke-width="2.5"
                  fill="none" stroke-linecap="round"/>
          </svg>
        </span>
      </h1>

      <!-- Sub-headline -->
      <p class="text-lg md:text-xl leading-relaxed max-w-2xl animate-fade-up"
         style="color: var(--text-muted); margin-bottom: 1.5rem; animation-delay:0.12s; animation-fill-mode:both;">
        I'm <strong style="color: var(--text); font-weight:600;">Abhishek Joshi</strong>, a software engineer 
        with 8.5+ years building systems that engineering teams actually rely on — from internal tools serving 
        thousands of daily users to data pipelines that drive decisions at scale.
      </p>

      <!-- CTAs -->
      <div class="flex flex-wrap gap-3 animate-fade-up"
           style="animation-delay:0.2s; animation-fill-mode:both;">
        <Button href="/work" variant="primary">
          View my work
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </Button>
        <Button href="mailto:hello@yourname.dev" variant="secondary">
          Get in touch
        </Button>
        <Button href="https://github.com/Abhishek-P-Joshi" variant="ghost" external>
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
          GitHub
        </Button>
      </div>
    </div>
  </section>

  <!-- ── Divider ────────────────────────────────────────── -->
  <div class="container-wide" style="padding-block: 1rem;">
    <div class="divider"></div>
  </div>

  <!-- ── Stack marquee ──────────────────────────────────── -->
  <section class="py-20 md:py-28 overflow-hidden" aria-label="Tech stack">
    <div class="container-wide">
      <p class="text-xs font-semibold tracking-widest uppercase" style="color: var(--text-faint); margin-bottom: 1rem;">
        Technologies I work with
      </p>
      <div class="flex items-center gap-3 flex-wrap">
        {stack.map(({ name }) => (
          <span class="tag text-xs font-medium px-3 py-1.5 whitespace-nowrap">{name}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Projects ───────────────────────────────────────── -->
  <section class="section" id="work">
    <div class="container-wide">
      <div class="reveal mb-12">
        <p class="section-label">Selected Work</p>
        <h2 class="section-title">Things I've built</h2>
        <p class="section-subtitle">
          A couple of side projects I designed and built end to end — from idea to production.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        {projects.map((project, i) => (
          <a
            href={project.href}
            target={project.external ? '_blank' : undefined}
            rel={project.external ? 'noopener noreferrer' : undefined}
            class="card p-8 flex flex-col gap-4 group reveal"
            style={`animation-delay:${i * 0.08}s; padding:10px`}
          >
            <!-- Project year + external indicator -->
            <div class="flex items-center justify-between">
              <span class="text-xs font-medium tabular-nums" style="color: var(--text-faint);">
                {project.year}
              </span>
              {project.external && (
                <svg class="w-3.5 h-3.5 opacity-30 group-hover:opacity-70 transition-opacity"
                     viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                     style="color: var(--text-muted);">
                  <line x1="7" y1="17" x2="17" y2="7"/>
                  <polyline points="7 7 17 7 17 17"/>
                </svg>
              )}
            </div>

            <!-- Color dot + title -->
            <div>
              <div class="w-8 h-8 rounded-lg mb-3 flex items-center justify-center"
                   style={`background-color: ${project.accentBg};`}>
                <div class="w-3 h-3 rounded-full" style={`background-color: ${project.accent};`}></div>
              </div>
              <h3 class="text-lg font-bold mb-1.5 group-hover:text-[var(--accent)] transition-colors duration-200">
                {project.title}
              </h3>
              <p class="text-sm leading-relaxed" style="color: var(--text-muted);">
                {project.description}
              </p>
            </div>

            <!-- Tags -->
            <div class="flex flex-wrap gap-1.5 mt-auto pt-2">
              {project.tags.map((tag) => (
                <span class="tag text-xs">{tag}</span>
              ))}
            </div>
          </a>
        ))}
      </div>

      <div class="mt-8 reveal">
        <Button href="/work" variant="ghost">
          View all projects
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </Button>
      </div>
    </div>
  </section>

  <!-- ── Divider ────────────────────────────────────────── -->
  <div class="container-wide" style="padding-block: 1rem;">
    <div class="divider"></div>
  </div>

  <!-- ── Writing ────────────────────────────────────────── -->
  <section class="section" id="writing">
    <div class="container-wide">
      <div class="reveal mb-10">
        <p class="section-label">Writing</p>
        <h2 class="section-title">From the blog</h2>
        <p class="section-subtitle">
          Occasionally writing about engineering, side projects, and whatever else is on my mind — technical or otherwise.
        </p>
      </div>

      <div class="flex flex-col reveal">
        {posts.map((post, i) => (
          <a
            href={`/blog/${post.slug}`}
            class="group flex flex-col sm:flex-row sm:items-start gap-6 sm:gap-10 transition-all duration-200
                   hover:bg-[var(--bg-soft)] -mx-4 px-4 rounded-lg"
            style={`padding-block: 0.5rem; ${i < posts.length - 1 ? 'border-bottom: 1px solid var(--border-mid);' : ''}`}
          >
            <!-- Date / meta -->
            <div class="flex-shrink-0 sm:w-32 text-xs tabular-nums pt-0.5" style="color: var(--text-faint);">
              <span class="block">{post.date}</span>
              <span class="block mt-1">{post.readTime} read</span>
            </div>

            <!-- Content -->
            <div class="flex-1 min-w-0 py-1">
              <h3 class="text-base font-semibold mb-4 leading-snug group-hover:text-[var(--accent)] transition-colors duration-200" style="padding-bottom:0.5rem;">
                {post.title}
              </h3>
              <div class="flex flex-wrap gap-1.5 pt-1 pb-3">
                {post.tags.map((tag) => (
                  <span class="tag text-xs">{tag}</span>
                ))}
              </div>
            </div>

            <!-- Arrow -->
            <div class="hidden sm:flex items-center self-center opacity-0 group-hover:opacity-100 -translate-x-2 group-hover:translate-x-0 transition-all duration-200"
                 style="color: var(--accent);">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="5" y1="12" x2="19" y2="12"/>
                <polyline points="12 5 19 12 12 19"/>
              </svg>
            </div>
          </a>
        ))}
      </div>

      <div class="mt-8 reveal">
        <Button href="/blog" variant="ghost">
          Read all posts
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </Button>
      </div>
    </div>
  </section>

  <!-- ── Divider ────────────────────────────────────────── -->
  <div class="container-wide" style="padding-block: 1rem;">
    <div class="divider"></div>
  </div>

  <!-- ── Connect ────────────────────────────────────────── -->
  <section class="section" id="connect">
    <div class="container-wide">
      <div class="max-w-2xl reveal">
        <p class="section-label">Contact</p>
        <h2 class="text-4xl md:text-5xl font-bold mb-5 leading-tight">
          Let's build something<br />
          <span style="color: var(--accent);">remarkable.</span>
        </h2>
        <p class="text-lg mb-8" style="color: var(--text-muted); margin-bottom: 1rem;">
          Whether you have a project in mind, want to chat about engineering, or just say hi —
          my inbox is always open.
        </p>
        <div class="flex flex-wrap gap-3">
          <Button href="mailto:hello@yourname.dev" variant="primary">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
            Say hello
          </Button>
        </div>
      </div>
    </div>
  </section>
</Layout>
