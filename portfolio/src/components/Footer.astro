---
const currentYear = new Date().getFullYear();

const links = {
  nav: [
    { href: '/',      label: 'Home'    },
    { href: '/work',  label: 'Work'    },
    { href: '/blog',  label: 'Writing' },
    { href: '/about', label: 'About'   },
  ],
  social: [
    { href: 'https://github.com/Abhishek-P-Joshi',      label: 'GitHub'   },
    { href: 'https://linkedin.com/in/abhishek-joshi-5619a676', label: 'LinkedIn' },
    { href: 'mailto:hello@ajtech.dev',            label: 'Email'    },
  ],
};
---

<footer class="mt-auto border-t" style="border-color: var(--border);">
  <div class="container-wide py-12 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-8 mb-12" style="padding:10px">
      <!-- Brand col -->
      <div class="md:col-span-1">
        <a href="/" class="inline-flex items-center gap-2.5 mb-4" aria-label="Home">
          <div class="relative w-7 h-7 flex items-center justify-center rounded-lg overflow-hidden"
               style="background-color: var(--text);">
            <span class="text-sm font-bold" style="font-family: 'Bricolage Grotesque', sans-serif; color: var(--bg);">AJ</span>
            <span class="absolute top-0.5 right-0.5 w-1.5 h-1.5 rounded-full"
                  style="background-color: #D97706;"></span>
          </div>
          <span class="font-semibold text-sm" style="font-family: 'Bricolage Grotesque', sans-serif;">
            Abhishek Joshi
          </span>
        </a>
        <p class="text-sm leading-relaxed max-w-xs" style="color: var(--text-muted);">
          Software engineer building reliable systems at the intersection of software, infrastructure, and data.
          Based in Bellevue, WA.
        </p>
      </div>

      <!-- Nav col -->
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest mb-4" style="color: var(--text-faint);">
          Navigation
        </p>
        <ul class="space-y-2.5">
          {links.nav.map(({ href, label }) => (
            <li>
              <a href={href}
                 class="text-sm transition-colors duration-150"
                 style="color: var(--text-muted);"
                 onmouseover="this.style.color='var(--text)'"
                 onmouseout="this.style.color='var(--text-muted)'"
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Social col -->
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest mb-4" style="color: var(--text-faint);">
          Connect
        </p>
        <ul class="space-y-2.5">
          {links.social.map(({ href, label }) => (
            <li>
              <a href={href}
                 target={href.startsWith('http') ? '_blank' : undefined}
                 rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}
                 class="text-sm inline-flex items-center gap-1.5 group transition-colors duration-150"
                 style="color: var(--text-muted);"
                 onmouseover="this.style.color='var(--text)'"
                 onmouseout="this.style.color='var(--text-muted)'"
              >
                {label}
                {href.startsWith('http') && (
                  <svg class="w-3 h-3 opacity-0 group-hover:opacity-100 transition-opacity -translate-x-0.5 group-hover:translate-x-0 duration-150"
                       viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="7" y1="17" x2="17" y2="7"/>
                    <polyline points="7 7 17 7 17 17"/>
                  </svg>
                )}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom row -->
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 pt-6 border-t"
         style="border-color: var(--border); padding:10px">
      <p class="text-xs" style="color: var(--text-faint);">
        &copy; {currentYear} Abhishek Joshi. All rights reserved.
      </p>
      <p class="text-xs" style="color: var(--text-faint);">
        Built with <a href="https://astro.build" target="_blank" rel="noopener"
          class="underline underline-offset-2 transition-colors hover:text-[var(--text)]"
          style="color: var(--text-faint);">Astro</a>
        &amp; <a href="https://tailwindcss.com" target="_blank" rel="noopener"
          class="underline underline-offset-2 transition-colors hover:text-[var(--text)]"
          style="color: var(--text-faint);">Tailwind</a>
      </p>
    </div>
  </div>
</footer>
