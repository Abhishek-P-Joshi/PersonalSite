---
export interface Props {
  href?: string;
  external?: boolean;
  class?: string;
}

const { href, external = false, class: className = '' } = Astro.props;
const Tag = href ? 'a' : 'div';
const attrs = href
  ? {
      href,
      ...(external
        ? { target: '_blank', rel: 'noopener noreferrer' }
        : {}),
    }
  : {};
---

<Tag
  class:list={['card group', className]}
  {...attrs}
>
  <slot />
</Tag>
